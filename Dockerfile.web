FROM node:22-alpine AS builder
WORKDIR /app

ARG NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
ARG NEXT_PUBLIC_DEPLOYMENT_MODE=local
ARG NEXT_PUBLIC_GATEWAY_URL=http://localhost:3300

ENV NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=$NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
ENV NEXT_PUBLIC_DEPLOYMENT_MODE=$NEXT_PUBLIC_DEPLOYMENT_MODE
ENV NEXT_PUBLIC_GATEWAY_URL=$NEXT_PUBLIC_GATEWAY_URL

# Install dependencies before copying the full source so Docker can cache them.
COPY signalpilot/web/package.json signalpilot/web/package-lock.json signalpilot/web/
RUN cd signalpilot/web && npm install --legacy-peer-deps

ARG SP_GATEWAY_INTERNAL_URL=http://gateway:3300
ENV SP_GATEWAY_INTERNAL_URL=$SP_GATEWAY_INTERNAL_URL

# Copy web app source
COPY signalpilot/web/ signalpilot/web/

# Build (standalone output bundles everything needed to run)
RUN cd signalpilot/web && npm run build

# ── Production runner ─────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ARG SP_GATEWAY_INTERNAL_URL=http://gateway:3300
ENV SP_GATEWAY_INTERNAL_URL=$SP_GATEWAY_INTERNAL_URL

# Copy standalone server (includes node_modules + server.js)
COPY --from=builder /app/signalpilot/web/.next/standalone/ ./
# Copy static assets into the paths used by the standalone server.
COPY --from=builder /app/signalpilot/web/.next/static ./.next/static
COPY --from=builder /app/signalpilot/web/public ./public

# Entrypoint: wait for local API key, then start standalone server
RUN printf '#!/bin/sh\ni=0\nwhile [ ! -f /shared/local_api_key ] && [ "$i" -lt 30 ]; do\n  sleep 1\n  i=$((i+1))\ndone\nif [ -f /shared/local_api_key ]; then\n  export SP_LOCAL_API_KEY="$(cat /shared/local_api_key)"\nfi\nexec node server.js\n' > /app/entrypoint.sh && chmod +x /app/entrypoint.sh

ENV PORT=3200
ENV HOSTNAME=0.0.0.0
EXPOSE 3200
CMD ["/app/entrypoint.sh"]
